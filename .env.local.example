# ─── Firebase Admin SDK ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Google OAuth2 (for Gmail + Calendar access) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ─── Google Cloud Pub/Sub (for Gmail push notifications) ───
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-notifications

# ─── OpenAI ───
OPENAI_API_KEY=

# ─── Tavily (web search) ───
TAVILY_API_KEY=

# ─── Telegram Bot ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── App Config ───
APP_SECRET_KEY=your-random-secret-for-encryption-min-32-chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron Secret (to protect cron endpoints) ───
CRON_SECRET=your-random-cron-secret
